PORT=3000
NODE_ENV=development

# Database Configuration (Supabase PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=postgres
DB_SSL=true

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=24h

# Admin Credentials (Default seed/fallback if table is not used)
ADMIN_DEFAULT_USER=admin
ADMIN_DEFAULT_PASS=admin12345
